{
  "name": "@keeveeg/opencode-wireguard-proxy",
  "version": "0.1.2",
  "description": "OpenCode plugin: route specific hostnames through WireGuard/AmneziaWG via wireproxy (userspace HTTP proxy)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "schema.json"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --external @opencode-ai/plugin && tsc --emitDeclarationOnly --outDir dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "wireguard",
    "amneziawg",
    "wireproxy",
    "vpn",
    "proxy",
    "split-tunnel"
  ],
  "author": "KeeVeeG",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KeeVeeG/opencode-wireguard-proxy"
  },
  "homepage": "https://github.com/KeeVeeG/opencode-wireguard-proxy",
  "bugs": {
    "url": "https://github.com/KeeVeeG/opencode-wireguard-proxy/issues"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.4.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.4.3",
    "bun-types": "^1.3.14",
    "typescript": "^5.9.0"
  }
}
